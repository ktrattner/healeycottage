---
import Base from "../layouts/Base.astro";
import rooms from "../content/rooms.json";
---

<Base title="Rooms | Healey Cottage">
  <h1>Rooms</h1>
  <p class="muted">
    Each room sleeps two. Availability is shown as busy blocks only. Requests require approval.
  </p>

  <div class="grid">
    {rooms.map((r) => (
      <article class="roomCard card hoverLift">
        <div class="cardTop">
          <h2><a class="titleLink" href={`/rooms/${r.slug}`}>{r.name}</a></h2>
          <span class="pill">Sleeps {r.sleeps}</span>
        </div>

        <p class="muted summary">{r.summary}</p>

        <div class="cardActions">
          <a class="link" href={`/rooms/${r.slug}`}>View details</a>
          <a class="link" href={`/request?room=${encodeURIComponent(r.name)}`}>Request</a>
        </div>
      </article>
    ))}
  </div>

  <style>
    .grid {
      margin-top: 18px;
      display: grid;
      gap: 14px;
      grid-template-columns: repeat(3, 1fr);
    }

    @media (max-width: 860px) {
      .grid {
        grid-template-columns: 1fr;
      }
    }

    .roomCard {
      display: grid;
      gap: 8px;
    }

    .cardTop {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
    }

    .cardTop h2 {
      margin: 0;
      font-size: 18px;
    }

    .titleLink,
    .titleLink:visited {
      color: #111;
      text-decoration: none;
    }
    .titleLink:hover {
      text-decoration: underline;
    }

    .cardActions {
      margin-top: 12px;
      display: flex;
      justify-content: space-between;
      font-size: 13px;
    }

    .summary {
      margin: 8px 0 0;
    }

    .link {
      text-decoration: none;
    }
    .link:hover {
      text-decoration: underline;
    }
  </style>
</Base>
