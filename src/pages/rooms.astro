---
import Base from "../layouts/Base.astro";
import RoomCard from "../components/RoomCard.astro";
import rooms from "../content/rooms.json";
---

<Base title="Rooms | Healey Cottage">
  <h1>Rooms</h1>
  <p class="lead intro">
    Most rooms sleep two. Hufflepuff sleeps up to four with a queen-sized bunk bed. Availability is shown as busy blocks only, and requests still require approval.
  </p>

  <div class="grid">
    {rooms.map((r) => (
      <RoomCard room={r} />
    ))}
  </div>

  <style>
    .intro {
      margin: 10px 0 0;
      max-width: 58ch;
    }

    @media (min-width: 861px) {
      .intro {
        max-width: none;
      }
    }

    .grid {
      margin-top: 12px;
      display: grid;
      gap: 12px;
      grid-template-columns: repeat(3, 1fr);
    }

    @media (max-width: 860px) {
      .grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</Base>
