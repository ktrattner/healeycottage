---
import Base from "../layouts/Base.astro";
import rooms from "../content/rooms.json";
const sent = Astro.url.searchParams.get("sent");
const roomOptions = rooms.map(({ slug, name }) => ({ slug, name }));
---

<Base title="Request a stay | Healey Cottage">
  <h1>Request a stay</h1>
  {sent && (
    <div class="banner success" role="status" aria-live="polite">
      Request received. You’ll get an email once it’s approved or declined.
    </div>
  )}
  <p class="lead intro">
    Submit a request. We review requests manually and usually reply by email within a couple of days.
    If timing is tight, mention it in your notes.
  </p>

  <form
    class="form card"
    method="post"
    action={import.meta.env.PUBLIC_APPS_SCRIPT_URL}
  >
    <div class="hp" aria-hidden="true">
      <label>
        Website
        <input name="website" autocomplete="off" tabindex="-1" />
      </label>
    </div>
    <input type="hidden" name="ts" id="tsField" value="" />
    <div id="selectedRoomNotice" class="banner roomNotice" hidden></div>

    <label>
      Name
      <input name="name" autocomplete="name" placeholder="Your name" required />
    </label>

    <label>
      Email
      <input name="email" type="email" autocomplete="email" placeholder="you@example.com" required />
    </label>

    <label>
      Room
      <select id="roomSelect" name="room" required>
        <option value="" disabled selected>Select a room</option>
        {roomOptions.map((room) => (
          <option value={room.name}>{room.name}</option>
        ))}
      </select>
      <p class="help">Only busy blocks are shown publicly. Details stay private.</p>
    </label>

    <div class="dateRow">
      <label>
        Check-in
        <input id="checkInField" name="checkIn" type="date" required />
      </label>

      <label>
        Check-out
        <input id="checkOutField" name="checkOut" type="date" required />
      </label>
    </div>
    <p class="help dateHelp">Check-out must be at least one day after check-in.</p>

    <label>
      Notes (optional)
      <textarea name="notes" rows="4" placeholder="Anything we should know? Timing flexibility, special requests, etc."></textarea>
    </label>

    <button type="submit" class="btn primary">Submit request</button>
    <p class="muted disclaimer">
      This is a private booking site for friends and family of Kyle and Brandon.
      If we sent you the link, you’re invited. If you found this by accident, we admire the initiative, but it’s probably a no.
    </p>
  </form>

  <script is:inline define:vars={{ roomOptions }}>
    (() => {
      const select = document.getElementById("roomSelect");
      if (!select) return;

      const ts = document.getElementById("tsField");
      if (ts) ts.value = String(Date.now());

      const checkIn = document.getElementById("checkInField");
      const checkOut = document.getElementById("checkOutField");
      const selectedRoomNotice = document.getElementById("selectedRoomNotice");

      const toIsoDate = (date) => {
        const year = date.getFullYear();
        const month = String(date.getMonth() + 1).padStart(2, "0");
        const day = String(date.getDate()).padStart(2, "0");
        return `${year}-${month}-${day}`;
      };

      const addDays = (isoDate, days) => {
        const [year, month, day] = isoDate.split("-").map(Number);
        const next = new Date(year, month - 1, day + days);
        return toIsoDate(next);
      };

      const today = toIsoDate(new Date());
      if (checkIn) checkIn.min = today;
      if (checkOut) checkOut.min = addDays(today, 1);

      const syncDates = () => {
        if (!checkIn || !checkOut) return;

        const minimumCheckOut = checkIn.value ? addDays(checkIn.value, 1) : addDays(today, 1);
        checkOut.min = minimumCheckOut;

        if (checkOut.value && checkOut.value < minimumCheckOut) {
          checkOut.value = minimumCheckOut;
        }

        const invalid = Boolean(checkIn.value && checkOut.value && checkOut.value <= checkIn.value);
        checkOut.setCustomValidity(invalid ? "Check-out must be after check-in." : "");
      };

      checkIn?.addEventListener("input", syncDates);
      checkOut?.addEventListener("input", syncDates);
      syncDates();

      const params = new URLSearchParams(window.location.search);
      const raw = (params.get("room") || "").trim();
      if (!raw) return;

      const norm = raw.toLowerCase();

      // Build a mapping of slugs and names (case-insensitive) to the option value (room name)
      const roomMap = new Map(
        (roomOptions || [])
          .map((r) => [
            [String(r.name).trim().toLowerCase(), r.name],
            [String(r.slug).trim().toLowerCase(), r.name],
          ])
          .flat()
      );

      const desired = roomMap.get(norm);
      if (!desired) return;

      select.value = desired;
      if (selectedRoomNotice) {
        selectedRoomNotice.hidden = false;
        selectedRoomNotice.textContent = `Requesting ${desired}. You can still change the room below.`;
      }
    })();
  </script>

  <style>
    .banner {
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 10px 12px;
      margin: 12px 0 14px;
      background: var(--card);
    }
    .banner.success {
      border-color: var(--accent-border);
      background: var(--accent-bg);
    }
    .roomNotice {
      margin: 0;
      border-color: rgba(0,0,0,.12);
      background: rgba(0,0,0,.03);
      font-weight: 500;
    }

    .form {
      margin-top: 14px;
      display: grid;
      gap: 12px;
      max-width: 640px;
    }
    .intro {
      margin: 10px 0 0;
      max-width: 62ch;
    }
    .form,
    .form * {
      box-sizing: border-box;
    }

    label {
      display: grid;
      gap: 6px;
      font-weight: 600;
      font-size: 14px;
    }

    input,
    select,
    textarea {
      width: 100%;
    }

    .help {
      margin: 6px 0 0;
      font-weight: 400;
      font-size: 13px;
      color: var(--muted);
    }
    .dateHelp {
      margin-top: -2px;
    }

    .dateRow {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }
    @media (max-width: 640px) {
      .dateRow { grid-template-columns: 1fr; }
    }

    .form .btn {
      justify-self: start;
      width: fit-content;
      padding: 12px 18px;
      font-size: 15px;
    }

    .disclaimer {
      margin-top: 10px;
      font-size: 12.5px;
      line-height: 1.45;
    }

    .hp {
      position: absolute;
      left: -10000px;
      top: auto;
      width: 1px;
      height: 1px;
      overflow: hidden;
    }
  </style>
</Base>
